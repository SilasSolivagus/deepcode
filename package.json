{
  "name": "@silassolivagus/deepcode",
  "version": "0.9.1",
  "description": "Terminal coding agent for DeepSeek, GLM & Kimi — multi-provider, built-in memory, reliable at a fraction of the cost (command: deepcode)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SilasSolivagus/deepcode.git"
  },
  "homepage": "https://github.com/SilasSolivagus/deepcode#readme",
  "bugs": "https://github.com/SilasSolivagus/deepcode/issues",
  "type": "module",
  "bin": {
    "deepcode": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run --passWithNoTests",
    "eval:automode": "tsx docs/specs/2026-07-01-auto-mode-eval/run.ts --only glm --repeat 3 --conc 1",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cli-highlight": "^2.1.11",
    "diff": "^5.2.2",
    "fast-glob": "^3.3.3",
    "ink": "^5.2.1",
    "jimp": "^1.6.1",
    "marked": "^12.0.2",
    "openai": "^6.42.0",
    "picomatch": "^4.0.4",
    "react": "^18.3.1",
    "shell-quote": "^1.8.4",
    "string-width": "^7.2.0",
    "undici": "^8.4.1",
    "yaml": "^2.9.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/diff": "^5.2.3",
    "@types/node": "^25.9.3",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^18.3.31",
    "@types/shell-quote": "^1.7.5",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
